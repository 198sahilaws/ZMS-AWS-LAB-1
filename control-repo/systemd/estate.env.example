# Copy to /etc/ansible/estate.env and fill in. Loaded by the systemd units so
# the timers have the same environment your shell would. Keep this file root-only
# (chmod 600) — it names the secret but holds no secret material itself.
AWS_REGION=eu-west-3
ANSIBLE_SECRET_NAME=ss-zms/ansible-credentials-l3qw1
CONTROL_REPO_DIR=/opt/control-repo
# If ansible was installed for a user (pip --user), make its bin dir findable:
# PATH=/usr/local/bin:/usr/bin:/bin:/home/ubuntu/.local/bin
# Optional: SNS topic ARN for failure alerts (scripts/notify-result.sh publishes
# here when a converge fails). Leave unset to only write the local failures log.
# ANSIBLE_ALERT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ansible-alerts
# ANSIBLE_LOG_DIR=/var/log/ansible
